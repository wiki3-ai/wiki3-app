{
  "name": "wiki3-app",
  "version": "0.5.2",
  "description": "Desktop app for running Wiki3.ai sites",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:arm64": "tauri build --target aarch64-apple-darwin",
    "version:bump": "./scripts/bump-version.sh",
    "notarize": "./scripts/notarize.sh",
    "release": "./scripts/release.sh",
    "release:draft": "./scripts/release.sh --draft",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-store": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
